{
  "name": "neo-bug-forge",
  "displayName": "Neo Bug Forge",
  "description": "AI bug fixer for VS Code & Cursor — click any red squiggle, get fixed code + diff + test in seconds.",
  "version": "1.5.8",
  "publisher": "neobugforge",
  "repository": {
    "type": "git",
    "url": "https://github.com/networkhack52/neo-bug-forge"
  },
  "homepage": "https://neobugforge.io",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "bug fix",
    "error fix",
    "debug",
    "quick fix",
    "code fix",
    "ai debugger",
    "error fixer",
    "claude",
    "cursor"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "neo-bug-forge.openPanel",
        "title": "Neo Bug Forge: Open Panel"
      },
      {
        "command": "neo-bug-forge.fixSelection",
        "title": "Neo Bug Forge: Fix Selected Code"
      },
      {
        "command": "neo-bug-forge.setApiKey",
        "title": "Neo Bug Forge: Set API Key"
      },
      {
        "command": "neo-bug-forge.fixDiagnostic",
        "title": "Neo Bug Forge: Fix Diagnostic"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "neo-bug-forge.fixSelection",
          "when": "editorHasSelection",
          "group": "1_modification@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "neo-bug-forge.fixSelection",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Neo Bug Forge",
      "properties": {
        "neo-bug-forge.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your Anthropic API key. Get one at https://console.anthropic.com"
        },
        "neo-bug-forge.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "description": "Claude model to use for bug fixing."
        },
        "neo-bug-forge.autoApply": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply fixes to the editor without confirmation."
        },
        "neo-bug-forge.context.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include related workspace files as context when fixing bugs."
        },
        "neo-bug-forge.context.maxFiles": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of context files to include (1–10)."
        },
        "neo-bug-forge.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show '⚡ Fix with Neo Bug Forge' in the lightbulb menu when VS Code detects a diagnostic error."
        },
        "neo-bug-forge.diagnostics.severityThreshold": {
          "type": "string",
          "enum": ["error", "warning", "all"],
          "enumDescriptions": [
            "Only show for errors (red squiggles)",
            "Show for errors and warnings",
            "Show for all diagnostics including hints"
          ],
          "default": "error",
          "description": "Minimum diagnostic severity that triggers the Neo Bug Forge lightbulb."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0"
  }
}
